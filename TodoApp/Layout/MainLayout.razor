@inherits LayoutComponentBase
<MudThemeProvider />
<MudPopoverProvider />

<MudDialogProvider />

<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="1" Dense>
        <MudIconButton Size="Size.Medium" Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="DrawerToggle" />
        <MudLink Href="" Typo="Typo.h5" Class="ml-3" Color="Color.Inherit">My Todo App</MudLink>
    </MudAppBar>

    <MudDrawer @bind-Open="@DrawerOpen" ClipMode="DrawerClipMode.Always" Style="box-sizing: border-box !important;">
        <MudNavMenu>
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
            <MudNavLink Href="@ApiEndpoints.ApiRoot"
                        Icon="@Icons.Material.Filled.Api"
                        Target="_blank">
                API
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Style="box-sizing: border-box !important;">
        <MudContainer MaxWidth="MaxWidth.False">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
